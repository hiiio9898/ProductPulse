# ===========================================
# ProductPulse 环境变量模板
# 用法：cp .env.example .env，然后填入真实值
# 禁止将真实 .env 提交到 Git
# ===========================================

# ---------- 应用 ----------
APP_ENV=dev                      # dev / staging / production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change_me_to_a_random_string

# ---------- 数据库 PostgreSQL 15 ----------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=productpulse
DB_USER=productpulse
DB_PASSWORD=change_me
# 完整连接串（若设置则以它为准）
# DATABASE_URL=postgresql://productpulse:change_me@127.0.0.1:5432/productpulse

# ---------- Redis 7 ----------
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ---------- CORS（前端地址，逗号分隔）----------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- 外部数据源：Sorftime ----------
# API/CLI 共用 Account-SK（正式后端集成用 Standard API）
SORFTIME_API_SK=
SORFTIME_API_BASE_URL=https://standardapi.sorftime.com/api
# MCP 专用 Account-SK（AI 日报时让 GLM 直连 Sorftime）
SORFTIME_MCP_SK=
SORFTIME_MCP_URL=https://mcp.sorftime.com
# 兼容旧字段（保留以防引用断裂）
SORFTIME_API_KEY=

# ---------- 1688 比价 ----------
# 说明：1688 采购货源查询通过 Sorftime 的 ProductSearchFromName (domain=601) 实现，
# 无需单独注册 1688 开放平台或企业认证，复用上方 SORFTIME_API_SK 即可。

# ---------- AI：智谱 GLM ----------
GLM_API_KEY=
GLM_MODEL_PRIMARY=glm-5.2        # 主力模型
GLM_MODEL_FALLBACK=glm-4.7       # 备用模型

# ---------- 日志 ----------
LOG_LEVEL=INFO