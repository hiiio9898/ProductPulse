# ===========================================
# ProductPulse 环境变量模板
# 用法：cp .env.example .env，然后填入真实值
# 禁止将真实 .env 提交到 Git
# ===========================================

# ---------- 应用 ----------
APP_ENV=dev                      # dev / staging / production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change_me_to_a_random_string

# ---------- 数据库 PostgreSQL 15 ----------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=productpulse
DB_USER=productpulse
DB_PASSWORD=change_me
# 完整连接串（若设置则以它为准）
# DATABASE_URL=postgresql://productpulse:change_me@127.0.0.1:5432/productpulse

# ---------- Redis 7 ----------
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ---------- CORS（前端地址，逗号分隔）----------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- 外部数据源：Sorftime ----------
SORFTIME_API_KEY=
SORFTIME_BASE_URL=https://api.sorftime.com

# ---------- 外部数据源：1688 开放平台 ----------
ALI1688_APP_KEY=
ALI1688_APP_SECRET=

# ---------- AI：智谱 GLM ----------
GLM_API_KEY=
GLM_MODEL_PRIMARY=glm-5.2        # 主力模型
GLM_MODEL_FALLBACK=glm-5.1       # 备用模型

# ---------- 日志 ----------
LOG_LEVEL=INFO